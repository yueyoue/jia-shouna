<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F6FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🏠 收纳空间"
            android:textSize="20sp"
            android:textStyle="bold" />
        <Button
            android:id="@+id/btn_add_space"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="+ 新建"
            android:textSize="13sp"
            android:backgroundTint="#FF8C42"
            android:textColor="#FFFFFF" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_spaces"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp"
        android:clipToPadding="false" />

    <LinearLayout
        android:id="@+id/empty_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🏠" android:textSize="48sp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="暂无空间" android:textSize="14sp" android:textColor="#999" android:layout_marginTop="8dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="点击右上角新建" android:textSize="12sp" android:textColor="#ccc" />
    </LinearLayout>
</LinearLayout>
