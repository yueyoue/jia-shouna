<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7FAFC"
    android:orientation="vertical">

    <!-- Method Tabs -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <TextView
            android:id="@+id/tab_scan"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="📷 扫码"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:background="@drawable/bg_tab_selected" />

        <TextView
            android:id="@+id/tab_photo"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="📸 拍照"
            android:textColor="#718096"
            android:textSize="13sp"
            android:background="@drawable/bg_tab_normal" />

        <TextView
            android:id="@+id/tab_manual"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="✏️ 手动"
            android:textColor="#718096"
            android:textSize="13sp"
            android:background="@drawable/bg_tab_normal" />

        <TextView
            android:id="@+id/tab_ai"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="AI"
            android:textColor="#718096"
            android:textSize="13sp"
            android:background="@drawable/bg_tab_normal" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="#FF8C42" />

    <ScrollView
        android:id="@+id/scroll_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Scan Container -->
            <LinearLayout
                android:id="@+id/scan_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="16dp"
                android:background="@drawable/bg_card_16"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="32dp">

                <TextView
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:background="@drawable/bg_quick_orange"
                    android:gravity="center"
                    android:text="📷"
                    android:textSize="28sp" />

                <TextView
                    android:id="@+id/tv_scan_hint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="点击下方按钮开始扫码"
                    android:textColor="#718096"
                    android:textSize="13sp" />

                <Button
                    android:id="@+id/btn_start_scan"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_button_primary"
                    android:paddingStart="32dp"
                    android:paddingEnd="32dp"
                    android:text="开始扫码"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- Match Result -->
            <LinearLayout
                android:id="@+id/match_result"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_match_result"
                android:orientation="vertical"
                android:padding="16dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_tag_green"
                        android:paddingTop="3dp" android:paddingBottom="3dp" android:paddingLeft="8dp" android:paddingRight="8dp"
                        android:text="✓ 自动匹配成功"
                        android:textColor="#22543D"
                        android:textSize="11sp" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_weight="1" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="耗时 185ms"
                        android:textColor="#A0AEC0"
                        android:textSize="11sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_tag_orange"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:background="@drawable/bg_quick_item"
                        android:gravity="center"
                        android:text="🥛"
                        android:textSize="32sp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="蒙牛纯牛奶 250ml"
                            android:textColor="#2D3748"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="品牌：蒙牛"
                            android:textColor="#718096"
                            android:textSize="12sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="建议分类：食品 › 乳制品"
                            android:textColor="#0E9F8E"
                            android:textSize="11sp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Fill Form -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_card_16"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✏️ 物品信息"
                    android:textColor="#4A5568"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <!-- Space Picker -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="存放位置 *"
                    android:textColor="#718096"
                    android:textSize="11sp" />

                <LinearLayout
                    android:id="@+id/space_picker"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:background="@drawable/bg_space_picker"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingTop="10dp" android:paddingBottom="10dp" android:paddingLeft="12dp" android:paddingRight="12dp">

                    <TextView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:background="@drawable/bg_gradient_orange"
                        android:gravity="center"
                        android:text="❄"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tv_space_name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="点击选择空间"
                            android:textColor="#2D3748"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/tv_space_path"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="请选择存放位置"
                            android:textColor="#718096"
                            android:textSize="10sp" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_tag_orange"
                        android:paddingTop="4dp" android:paddingBottom="4dp" android:paddingLeft="10dp" android:paddingRight="10dp"
                        android:text="＋新建空间"
                        android:textColor="#FF8C42"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="›"
                        android:textColor="#CBD5E0"
                        android:textSize="16sp" />
                </LinearLayout>

                <!-- Quantity & Unit -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="数量 *"
                            android:textColor="#718096"
                            android:textSize="11sp" />

                        <EditText
                            android:id="@+id/et_quantity"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:layout_marginTop="4dp"
                            android:background="@drawable/bg_input_new"
                            android:inputType="number"
                            android:paddingTop="10dp" android:paddingBottom="10dp" android:paddingLeft="12dp" android:paddingRight="12dp"
                            android:text="1"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <View
                        android:layout_width="10dp"
                        android:layout_height="0dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="单位"
                            android:textColor="#718096"
                            android:textSize="11sp" />

                        <EditText
                            android:id="@+id/et_unit"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:layout_marginTop="4dp"
                            android:background="@drawable/bg_input_new"
                            android:hint="个"
                            android:paddingTop="10dp" android:paddingBottom="10dp" android:paddingLeft="12dp" android:paddingRight="12dp"
                            android:textSize="13sp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Purchase Date & Expiry -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="生产日期"
                            android:textColor="#718096"
                            android:textSize="11sp" />

                        <EditText
                            android:id="@+id/et_purchase_date"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:layout_marginTop="4dp"
                            android:background="@drawable/bg_input_new"
                            android:clickable="true"
                            android:focusable="false"
                            android:hint="点击选择日期"
                            android:paddingTop="10dp" android:paddingBottom="10dp" android:paddingLeft="12dp" android:paddingRight="12dp"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <View
                        android:layout_width="10dp"
                        android:layout_height="0dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="保质期"
                            android:textColor="#718096"
                            android:textSize="11sp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:orientation="horizontal">

                            <EditText
                                android:id="@+id/et_expiry_days"
                                android:layout_width="0dp"
                                android:layout_height="44dp"
                                android:layout_weight="1"
                                android:background="@drawable/bg_input_new"
                                android:hint="如 365"
                                android:inputType="number"
                                android:paddingTop="10dp" android:paddingBottom="10dp" android:paddingLeft="12dp" android:paddingRight="12dp"
                                android:textSize="13sp" />

                            <Spinner
                                android:id="@+id/sp_expiry_unit"
                                android:layout_width="72dp"
                                android:layout_height="44dp"
                                android:layout_marginStart="6dp"
                                android:background="@drawable/bg_input_new" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- Auto-calculated Expiry Date -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="过期日期（自动计算）"
                        android:textColor="#718096"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/tv_expiry_date_auto"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:layout_marginTop="4dp"
                        android:background="@drawable/bg_input_new"
                        android:gravity="center_vertical"
                        android:hint="输入生产日期和保质期后自动计算"
                        android:paddingTop="10dp" android:paddingBottom="10dp" android:paddingLeft="12dp" android:paddingRight="12dp"
                        android:textColor="#2D3748"
                        android:textSize="13sp" />
                </LinearLayout>

                <!-- Price & Threshold -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="购买价格"
                            android:textColor="#718096"
                            android:textSize="11sp" />

                        <EditText
                            android:id="@+id/et_price"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:layout_marginTop="4dp"
                            android:background="@drawable/bg_input_new"
                            android:hint="¥ 可选"
                            android:inputType="numberDecimal"
                            android:paddingTop="10dp" android:paddingBottom="10dp" android:paddingLeft="12dp" android:paddingRight="12dp"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <View
                        android:layout_width="10dp"
                        android:layout_height="0dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="库存阈值"
                            android:textColor="#718096"
                            android:textSize="11sp" />

                        <EditText
                            android:id="@+id/et_threshold"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:layout_marginTop="4dp"
                            android:background="@drawable/bg_input_new"
                            android:hint="低于此数量提醒"
                            android:inputType="number"
                            android:paddingTop="10dp" android:paddingBottom="10dp" android:paddingLeft="12dp" android:paddingRight="12dp"
                            android:textSize="13sp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Name -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="物品名称 *"
                    android:textColor="#718096"
                    android:textSize="11sp" />

                <EditText
                    android:id="@+id/et_name"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:layout_marginTop="4dp"
                    android:background="@drawable/bg_input_new"
                    android:hint="输入物品名称"
                    android:paddingTop="10dp" android:paddingBottom="10dp" android:paddingLeft="12dp" android:paddingRight="12dp"
                    android:textSize="13sp" />

                <!-- Barcode -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="条形码"
                    android:textColor="#718096"
                    android:textSize="11sp" />

                <EditText
                    android:id="@+id/et_barcode"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:layout_marginTop="4dp"
                    android:background="@drawable/bg_input_new"
                    android:hint="条形码"
                    android:paddingTop="10dp" android:paddingBottom="10dp" android:paddingLeft="12dp" android:paddingRight="12dp"
                    android:textSize="13sp" />

                <!-- Tags -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="物品标签"
                    android:textColor="#718096"
                    android:textSize="11sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:id="@+id/ll_tags"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal" />

                    <TextView
                        android:id="@+id/btn_add_tag"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_icon_btn_rounded"
                        android:paddingTop="4dp" android:paddingBottom="4dp" android:paddingLeft="8dp" android:paddingRight="8dp"
                        android:text="+ 添加"
                        android:textColor="#A0AEC0"
                        android:textSize="11sp" />
                </LinearLayout>

                <!-- Photos -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="物品照片 (最多 3 张)"
                    android:textColor="#718096"
                    android:textSize="11sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:id="@+id/ll_photos"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal" />

                    <TextView
                        android:id="@+id/btn_add_photo"
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:background="@drawable/bg_upload_dashed"
                        android:gravity="center"
                        android:text="+\n添加"
                        android:textColor="#718096"
                        android:textSize="11sp" />
                </LinearLayout>

                <!-- Note -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="备注"
                    android:textColor="#718096"
                    android:textSize="11sp" />

                <EditText
                    android:id="@+id/et_note"
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:layout_marginTop="4dp"
                    android:background="@drawable/bg_input_new"
                    android:gravity="top"
                    android:hint="选填，例如：明天早餐用"
                    android:paddingTop="10dp" android:paddingBottom="10dp" android:paddingLeft="12dp" android:paddingRight="12dp"
                    android:textSize="13sp" />

                <!-- Privacy Toggle -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:background="@drawable/bg_privacy_card"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🔒"
                            android:textSize="18sp" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="仅自己可见"
                                android:textColor="#2D3748"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="开启后，其他家庭成员无法查看此物品"
                                android:textColor="#A0AEC0"
                                android:textSize="11sp" />
                        </LinearLayout>

                        <Switch
                            android:id="@+id/sw_private"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Bottom spacer -->
            <View
                android:layout_width="match_parent"
                android:layout_height="80dp" />
        </LinearLayout>
    </ScrollView>

    <!-- Save Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:orientation="horizontal"
        android:paddingTop="12dp" android:paddingBottom="12dp" android:paddingLeft="16dp" android:paddingRight="16dp">

        <Button
            android:id="@+id/btn_save_continue"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="10dp"
            android:background="@drawable/bg_button_save"
            android:text="✓ 保存继续"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btn_save"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/bg_button_save"
            android:text="✓ 保存返回"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
